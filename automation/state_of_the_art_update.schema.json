{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "needs_update",
    "reason",
    "replacement_managed_block_markdown"
  ],
  "properties": {
    "needs_update": {
      "type": "boolean"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "replacement_managed_block_markdown": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
