{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec Observatory Watchdog Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "reason",
    "feedback_markdown"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "accept",
        "rollback"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "feedback_markdown": {
      "type": "string",
      "minLength": 1
    }
  }
}
